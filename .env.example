# PacketPath Environment Variables
# Copy this file to .env and fill in the values for your deployment.
# NEVER commit .env to version control.

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://packetpath:packetpath@localhost:5432/packetpath

# ─── Application ──────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development
APP_BASE_URL=https://your-domain.com

# ─── Security ─────────────────────────────────────────────────────────────────
# Session signing secret — use a long random string in production
SESSION_SECRET=change-me-to-a-long-random-string-in-production

# AES-256-GCM key for encrypting PHI fields at rest (64 hex chars = 32 bytes)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DB_ENCRYPTION_KEY=

# AES-256-GCM key for encrypting TOTP secrets at rest (64 hex chars = 32 bytes)
MFA_ENCRYPTION_KEY=

# HMAC key for blind index lookups on encrypted fields
BLIND_INDEX_KEY=

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key
SMTP_FROM=noreply@your-domain.com
SMTP_FROM_NAME=PacketPath

# ─── SMS (Twilio) ─────────────────────────────────────────────────────────────
# Required for SMS signing notifications
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+15551234567

# ─── Error Monitoring (Sentry) ────────────────────────────────────────────────
# Get your DSN from https://sentry.io -> Project Settings -> Client Keys
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_RELEASE=

# ─── AWS S3 (HIPAA-Compliant Storage) ────────────────────────────────────────
# Optional: For storing signed PDFs in S3 with Object Lock
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=packetpath-signed-documents
