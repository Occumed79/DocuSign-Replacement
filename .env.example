# Database (required)
DATABASE_URL=postgresql://packetpath:packetpath@localhost:5432/packetpath

# API Server
PORT=8080

# Frontend (optional — defaults shown)
# VITE_PORT=5173
# BASE_PATH=/

# SMTP (optional — enables email sending for e-signature notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=you@example.com
# SMTP_PASS=your-app-password
# SMTP_FROM=no-reply@occumed.com
# SMTP_FROM_NAME=Occu-Med PacketPath
